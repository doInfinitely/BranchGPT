# ── Database (Neon Postgres) ────────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/spindle?sslmode=require

# ── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=   # Generate with: openssl rand -base64 32

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Email magic link (optional — omit to disable email auth)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@spindle.app

# ── LLM API Keys (for managed/server-side mode) ────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Tavily Search ──────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Unlimited accounts (comma-separated emails) ────────────
UNLIMITED_EMAILS=do.infinitely@gmail.com

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
